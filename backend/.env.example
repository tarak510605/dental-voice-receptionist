# ══════════════════════════════════════════════════════════════════════════════
# QuensultingAI Dental Clinic – AI Receptionist  |  Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="QuensultingAI Dental Clinic AI Receptionist"
APP_VERSION="1.0.0"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Path to your Google Service Account credentials JSON file
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json

# The ID from your Google Sheets URL:
# https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Name of the worksheet tab within the spreadsheet
GOOGLE_SHEETS_WORKSHEET_NAME=Appointments

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# The Gmail account that sends confirmation emails
GMAIL_SENDER_EMAIL=your_gmail_address@gmail.com

# Gmail App Password (NOT your main Gmail password).
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2FA to be enabled on your Google account.
GMAIL_APP_PASSWORD=your_16_char_app_password

# Display name shown in the From field of emails
GMAIL_SENDER_NAME="QuensultingAI Dental Clinic"

# ── RetellAI ──────────────────────────────────────────────────────────────────
# Your RetellAI API key from: https://app.retellai.com/dashboard
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Webhook secret for signature verification (if configured in RetellAI)
RETELL_WEBHOOK_SECRET=

# Your RetellAI agent ID (shown after creating the agent)
RETELL_AGENT_ID=agent_xxxxxxxxxxxxxxxx

# ── Clinic Configuration ──────────────────────────────────────────────────────
# IANA timezone name for the clinic
TIMEZONE=Asia/Kolkata

# Duration of each appointment slot in minutes
SLOT_DURATION_MINUTES=30

# ── Retry Configuration ───────────────────────────────────────────────────────
SHEETS_MAX_RETRIES=3
SHEETS_RETRY_DELAY_SECONDS=1.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
